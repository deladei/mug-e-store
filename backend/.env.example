# Copy to .env and fill in real values. NEVER commit .env.
# Money is integer pesewas everywhere (1 GHS = 100 pesewas).

# Postgres connection string, e.g. postgres://user:pass@localhost:5432/coffeemug?sslmode=disable
DATABASE_URL=

# HS256 signing secret for access tokens (use a long random string)
JWT_SECRET=

# Paystack TEST secret key (sk_test_...). Never commit a real key.
PAYSTACK_SECRET_KEY=

# Paystack API base URL
PAYSTACK_BASE_URL=https://api.paystack.co

# HTTP listen port
PORT=8080

# Flat delivery fee in pesewas (default 1000 = GHS 10.00)
DELIVERY_FEE_PESEWAS=1000

# Allowed CORS origin for the frontend (e.g. http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000
